# Server Configuration
PORT=3001
NODE_ENV=production

# News API Key (optional, for additional news sources)
# Get free API key at: https://newsapi.org/register
NEWS_API_KEY=your_news_api_key_here

# Update schedule (cron expression)
# Default: 0 8 * * * = Every day at 8:00 AM
UPDATE_SCHEDULE=0 8 * * *

# CORS allowed origins (comma separated)
# For production, set your frontend domain
CORS_ORIGINS=https://musicainsight.netlify.app,http://localhost:5173
